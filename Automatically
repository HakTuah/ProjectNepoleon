local function runFarm()
    if getCharacter():FindFirstChild("StandMorph") then
        pcall(function() getRemoteFunction():InvokeServer("ToggleStand", "Toggle") end)
        task.wait(0.5)
    end

    currentStatus = "Teleporting..."
    teleportToCoords()
    task.wait(5)

    anchorConn = RunService.Stepped:Connect(function()
        pcall(function()
            if not currentHiddenTarget then return end
            local hrp = getRootPart()
            hrp.AssemblyLinearVelocity = Vector3.zero
            hrp.AssemblyAngularVelocity = Vector3.zero
            hrp.CFrame = currentHiddenTarget
            local char = LocalPlayer.Character
            if char then
                for _, v in pairs(char:GetDescendants()) do
                    if v:IsA("BasePart") then v.CanCollide = false end
                end
            end
        end)
    end)

    while farmEnabled do
        task.wait(0.2)
        sellInventory()

        local foundAny = false

        for itemName in pairs(targetSet) do
            if not farmEnabled then break end

            local prompts = registeredItems[itemName]
            if not (prompts and #prompts > 0) then continue end

            local prompt = prompts[1]
            local parent = prompt and prompt.Parent
            if not parent then continue end

            foundAny = true
            currentStatus = "→ " .. itemName

            local shouldCollect = true
            if isFullOfItem(itemName) then
                sellInventory()
                shouldCollect = true
            end

            if shouldCollect then
                local targetCFrame = parent:GetModelCFrame() - Vector3.new(0, 10, 0)
                currentHiddenTarget = targetCFrame
                getRootPart().CFrame = targetCFrame
                repeat task.wait() until
                    (getRootPart().Position - parent:GetModelCFrame().p).Magnitude <= 40
                    or not farmEnabled
                    or not parent.Parent

                if not farmEnabled then break end
                if not parent.Parent then continue end

                local pingDelay = math.clamp(getPing() / 220, 0, 0.1)
                task.wait(0.45 + pingDelay)

                if not farmEnabled then break end

                sellInventory()

                repeat
                    pcall(function()
                        prompt.RemoteEvent:FireServer()
                    end)
                    task.wait()
                until not farmEnabled
                    or not (parent:FindFirstChild("ProximityPrompt") and targetSet[itemName])

                if farmEnabled then
                    statsCollected += 1
                    currentStatus = "Farming"
                end

                sellInventory()
            end
        end

        if not foundAny then
            serverHop()
            return
        end
    end

    currentHiddenTarget = nil
    if anchorConn then anchorConn:Disconnect() anchorConn = nil end
    currentStatus = "Idle"
end

