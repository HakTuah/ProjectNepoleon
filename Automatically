local itemESPConn = nil

local function addItemESP(v)
    local itemPart = v:FindFirstChildOfClass("MeshPart") or v:FindFirstChildOfClass("Part")
    local prox = v:FindFirstChild("ProximityPrompt")
    if not (itemPart and prox and itemPart.Transparency < 1) then return end
    local itemName = prox.ObjectText ~= "" and prox.ObjectText or v.Name
    if not v:FindFirstChild("SFItemESP") then
        local hl = Instance.new("Highlight")
        hl.Name = "SFItemESP"
        hl.FillTransparency = 0.5
        hl.FillColor = Color3.fromRGB(0, 150, 230)
        hl.OutlineTransparency = 0
        hl.OutlineColor = Color3.fromRGB(100, 210, 255)
        hl.Adornee = v
        hl.Parent = v
    end
    if not v:FindFirstChild("SFItemESPLabel") then
        local bb = Instance.new("BillboardGui")
        bb.Name = "SFItemESPLabel"
        bb.Adornee = itemPart
        bb.Size = UDim2.new(0, 200, 0, 38)
        bb.StudsOffset = Vector3.new(0, 3.5, 0)
        bb.AlwaysOnTop = true
        bb.Parent = v
        local tl = Instance.new("TextLabel")
        tl.Size = UDim2.new(1, 0, 1, 0)
        tl.BackgroundTransparency = 1
        tl.Text = itemName
        tl.TextColor3 = Color3.fromRGB(140, 225, 255)
        tl.TextSize = 15
        tl.TextStrokeTransparency = 0
        tl.TextStrokeColor3 = Color3.fromRGB(0, 80, 160)
        tl.Font = Enum.Font.GothamBold
        tl.Parent = bb
    end
end

local function enableESP()
    for _, v in pairs(workspace.Item_Spawns.Items:GetChildren()) do pcall(addItemESP, v) end
    itemESPConn = workspace.Item_Spawns.Items.ChildAdded:Connect(function(v)
        task.wait(0.1)
        pcall(addItemESP, v)
    end)
end

local function disableESP()
    if itemESPConn then itemESPConn:Disconnect() itemESPConn = nil end
    for _, v in pairs(workspace.Item_Spawns.Items:GetChildren()) do
        pcall(function()
            local h = v:FindFirstChild("SFItemESP") if h then h:Destroy() end
            local b = v:FindFirstChild("SFItemESPLabel") if b then b:Destroy() end
        end)
    end
end

